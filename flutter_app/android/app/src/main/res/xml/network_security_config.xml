<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Trust user-installed certificates (e.g. mkcert CA) in addition to system CAs -->
    <base-config>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
